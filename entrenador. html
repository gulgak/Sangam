<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0a0a0a">
<meta name="apple-mobile-web-app-title" content="Rutina FSHD">
<meta name="application-name" content="Rutina FSHD">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<link rel="manifest" href='data:application/manifest+json;charset=utf-8,{"name":"Rutina FSHD","short_name":"Rutina FSHD","description":"Entrenador personal adaptado a FSHD","start_url":".","display":"standalone","background_color":"%230a0a0a","theme_color":"%230a0a0a","orientation":"portrait","icons":[{"src":"data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 fill=%22%23e63946%22 rx=%2220%22/><text x=%2250%22 y=%2262%22 font-size=%2240%22 text-anchor=%22middle%22 fill=%22white%22 font-family=%22sans-serif%22 font-weight=%22bold%22>💪</text></svg>","sizes":"192x192","type":"image/svg+xml"},{"src":"data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 fill=%22%23e63946%22 rx=%2220%22/><text x=%2250%22 y=%2262%22 font-size=%2240%22 text-anchor=%22middle%22 fill=%22white%22 font-family=%22sans-serif%22 font-weight=%22bold%22>💪</text></svg>","sizes":"512x512","type":"image/svg+xml"}]}'>
<title>Rutina FSHD — Entrenador</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0a0a;--surface:#141414;--card:#1c1c1c;--card-hi:#242424;--border:#2e2e2e;--text:#f2f2f2;--muted:#888;--red:#e63946;--green:#2ecc71;--blue:#3b82f6;--gold:#f59e0b;--purple:#8b5cf6;--cyan:#06b6d4;--yellow:#eab308;--skin:#f4c4a0;--muscle:#e63946;--band:#eab308;--dumbbell:#4b5563}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{overscroll-behavior:none}
body{background:var(--bg);color:var(--text);font-family:'Space Grotesk',sans-serif;min-height:100vh;overflow-x:hidden;user-select:none;-webkit-user-select:none}
.home{padding:32px 20px 100px;max-width:600px;margin:0 auto}
.hero{text-align:center;padding:20px 0 32px;position:relative}
.lang-toggle{position:absolute;top:12px;right:0;background:var(--card);border:1px solid var(--border);color:var(--text);padding:6px 12px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s}
.lang-toggle:active{transform:scale(.95)}
.lang-toggle:hover{border-color:var(--red)}
.hero::after{content:'';display:block;width:40px;height:3px;background:var(--red);margin:16px auto 0;border-radius:2px}
.hero-label{font-size:11px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:8px}
.hero-title{font-family:'Bebas Neue',sans-serif;font-size:44px;letter-spacing:2px;line-height:1}
.hero-subtitle{font-size:13px;color:var(--muted);margin-top:10px}
.toggle-row{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;cursor:pointer}
.toggle-row-label{display:flex;align-items:center;gap:12px;font-size:14px;font-weight:500}
.toggle-icon{font-size:22px}
.toggle-switch{width:48px;height:28px;background:var(--border);border-radius:14px;position:relative;transition:background .25s;flex-shrink:0}
.toggle-switch.on{background:var(--green)}
.toggle-switch::after{content:'';position:absolute;top:3px;left:3px;width:22px;height:22px;background:#fff;border-radius:50%;transition:transform .25s}
.toggle-switch.on::after{transform:translateX(20px)}
.volume-row{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;margin-bottom:20px}
.volume-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.volume-label{font-size:13px;font-weight:500;display:flex;align-items:center;gap:10px}
.volume-value{font-family:'Bebas Neue',sans-serif;color:var(--red);font-size:18px;letter-spacing:1px}
.volume-slider{width:100%;height:6px;background:var(--border);border-radius:3px;outline:none;-webkit-appearance:none;appearance:none}
.volume-slider::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;border-radius:50%;background:var(--red);cursor:pointer;border:2px solid var(--text)}
.volume-slider::-moz-range-thumb{width:22px;height:22px;border-radius:50%;background:var(--red);cursor:pointer;border:2px solid var(--text)}
.test-btns{display:flex;gap:10px;margin-bottom:20px}
.test-btn{flex:1;background:var(--card);border:1px solid var(--border);color:var(--text);padding:12px;border-radius:12px;font-family:inherit;font-weight:600;font-size:13px;cursor:pointer;text-transform:uppercase;letter-spacing:1px}
.test-btn:active{transform:scale(.97)}
#debugLog{font-size:11px;color:var(--muted);padding:8px 12px;background:var(--card);border-radius:10px;margin-bottom:20px;display:none;font-family:monospace;line-height:1.5}
.section-title{font-size:11px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin:28px 0 14px;padding-left:4px}
.block-card{background:linear-gradient(135deg,var(--card),var(--card-hi));border:1px solid var(--border);border-radius:18px;padding:20px;margin-bottom:14px;position:relative;overflow:hidden;cursor:pointer;transition:transform .15s}
.block-card:active{transform:scale(.98)}
.block-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--accent,var(--red))}
.block-card[data-type="breathing"]{--accent:var(--blue)}
.block-card[data-type="core"]{--accent:var(--red)}
.block-card[data-type="arms"]{--accent:var(--yellow)}
.block-card[data-type="compex"]{--accent:var(--gold)}
.block-card[data-type="stretch"]{--accent:var(--green)}
.block-card[data-type="bike"]{--accent:#fb923c}
.block-card[data-type="bed"]{--accent:var(--purple)}
.block-time{font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--muted);letter-spacing:1px;margin-bottom:4px}
.block-title{font-size:19px;font-weight:700;letter-spacing:-.3px;margin-bottom:8px}
.block-meta{display:flex;gap:14px;font-size:12px;color:var(--muted)}
.block-chevron{position:absolute;right:20px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:22px}
.trainer{position:fixed;inset:0;background:var(--bg);z-index:200;display:none;flex-direction:column}
.trainer.open{display:flex}
.trainer-top{padding:12px 14px;display:flex;align-items:center;justify-content:space-between;background:var(--surface);border-bottom:1px solid var(--border)}
.close-btn,.skip-btn{background:transparent;border:none;color:var(--text);cursor:pointer;width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px}
.close-btn:active,.skip-btn:active{background:var(--card)}
.trainer-counter{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:1.5px;text-align:center}
.trainer-counter small{display:block;font-size:10px;color:var(--muted);letter-spacing:2px;margin-top:2px}
.trainer-progress{height:4px;background:var(--border)}
.trainer-progress-fill{height:100%;background:var(--red);transition:width .3s}
.trainer-image{width:100%;height:32vh;background:#ffffff;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.trainer-image img{max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain}
.trainer-image .fallback-emoji{font-size:90px;filter:grayscale(0.2)}
.trainer-image .fallback-label{position:absolute;bottom:10px;font-size:11px;color:#888;letter-spacing:2px;text-transform:uppercase}
.timer-overlay{position:absolute;bottom:12px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.75);padding:8px 24px;border-radius:12px;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);box-shadow:0 4px 16px rgba(0,0,0,.3);pointer-events:none;z-index:10}
.timer-overlay-display{font-family:'Bebas Neue',sans-serif;font-size:56px;line-height:1;letter-spacing:4px;color:#fff;font-variant-numeric:tabular-nums}
.timer-overlay-display.warning{color:var(--gold)}
.timer-overlay-display.danger{color:var(--red);animation:pulse .5s ease infinite alternate}
.trainer-content{flex:1;padding:16px 22px 10px;overflow-y:auto}
.trainer-name{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:1.5px;line-height:1;margin-bottom:4px}
.trainer-reps{font-size:12px;color:var(--red);font-weight:700;text-transform:uppercase;letter-spacing:2px;margin-bottom:12px}
.trainer-desc{font-size:13px;line-height:1.5;color:var(--muted);margin-bottom:12px}
.cue-box{background:rgba(59,130,246,.1);border:2px solid rgba(59,130,246,.4);border-radius:14px;padding:16px;margin-bottom:12px;text-align:center;min-height:70px;display:flex;align-items:center;justify-content:center;transition:all .3s}
.cue-text{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:3px;color:var(--blue);line-height:1}
.cue-text.exhale{color:var(--cyan)}
.cue-box.exhale{background:rgba(6,182,212,.1);border-color:rgba(6,182,212,.4)}
.cue-text.hold{color:var(--gold)}
.cue-box.hold{background:rgba(245,158,11,.1);border-color:rgba(245,158,11,.4)}
.cue-text.contract{color:var(--red)}
.cue-box.contract{background:rgba(230,57,70,.1);border-color:rgba(230,57,70,.4)}
.cue-text.relax{color:var(--green)}
.cue-box.relax{background:rgba(46,204,113,.1);border-color:rgba(46,204,113,.4)}
.big-timer{text-align:center;padding:4px 0}
.big-timer-label{font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:2px}
.big-timer-display{font-family:'Bebas Neue',sans-serif;font-size:64px;line-height:1;letter-spacing:4px;color:var(--text);font-variant-numeric:tabular-nums}
.big-timer-display.warning{color:var(--gold)}
.big-timer-display.danger{color:var(--red);animation:pulse .5s ease infinite alternate}
@keyframes pulse{from{transform:scale(1)}to{transform:scale(1.05)}}
.trainer-controls{display:flex;gap:10px;padding:14px 18px 22px;background:var(--surface);border-top:1px solid var(--border)}
.ctrl-btn{flex:1;background:var(--card);border:1px solid var(--border);color:var(--text);padding:16px 10px;border-radius:14px;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:13px;cursor:pointer;text-transform:uppercase;letter-spacing:1px}
.ctrl-btn.primary{background:linear-gradient(135deg,var(--red),#c0392b);border-color:var(--red);flex:2;color:#fff}
.ctrl-btn.primary.pause{background:linear-gradient(135deg,var(--gold),#d97706);border-color:var(--gold)}
.ctrl-btn:active:not(:disabled){transform:scale(.97)}
.trainer.rest .trainer-image,.trainer.ready .trainer-image,.trainer.complete .trainer-image{display:none}
.trainer.rest .trainer-content,.trainer.ready .trainer-content,.trainer.complete .trainer-content{display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center}
.trainer.rest .trainer-content{background:linear-gradient(180deg,var(--bg),#0a1f0a)}
.rest-badge{font-size:11px;letter-spacing:4px;color:var(--green);text-transform:uppercase;padding:8px 20px;background:rgba(46,204,113,.1);border:1px solid rgba(46,204,113,.3);border-radius:20px;margin-bottom:20px}
.rest-next{font-size:12px;color:var(--muted);margin-top:20px;letter-spacing:1px;text-transform:uppercase}
.rest-next-name{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:1.5px;margin-top:4px}
.trainer.ready .trainer-content{background:linear-gradient(180deg,var(--bg),#1a0a0a)}
.ready-countdown{font-family:'Bebas Neue',sans-serif;font-size:160px;line-height:1;color:var(--red);letter-spacing:4px;animation:countPulse 1s ease infinite}
@keyframes countPulse{0%{transform:scale(1);opacity:1}50%{transform:scale(1.15);opacity:.8}100%{transform:scale(1);opacity:1}}
.ready-label{font-size:14px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:12px}
.trainer.complete .trainer-content{background:linear-gradient(180deg,var(--bg),#0a1f1a)}
.complete-icon{font-size:80px;margin-bottom:20px;animation:complete .6s ease}
@keyframes complete{0%{transform:scale(0) rotate(-180deg);opacity:0}100%{transform:scale(1) rotate(0);opacity:1}}
.complete-title{font-family:'Bebas Neue',sans-serif;font-size:44px;letter-spacing:2px;color:var(--green);margin-bottom:8px}
.complete-sub{font-size:14px;color:var(--muted);letter-spacing:1px}
.day-progress{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 16px;margin-bottom:20px}
.day-progress-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.day-progress-label{font-size:12px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted)}
.day-progress-count{font-family:'Bebas Neue',sans-serif;font-size:18px;color:var(--red)}
.day-progress-bar{height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.day-progress-fill{height:100%;background:linear-gradient(90deg,var(--red),#ff6b6b);border-radius:3px;transition:width .5s}
</style>
</head>
<body>

<div class="home" id="home">
  <div class="hero">
    <div class="hero-label" data-t="heroLabel">Entrenador Personal</div>
    <div class="hero-title">RUTINA FSHD</div>
    <div class="hero-subtitle" data-t="heroSubtitle">Adaptada a tu movilidad</div>
    <button class="lang-toggle" id="langToggle" onclick="toggleLang()">🇪🇸 ES</button>
  </div>

  <div class="toggle-row" onclick="toggleVoice()">
    <div class="toggle-row-label">
      <span class="toggle-icon" id="voiceIcon">🔊</span>
      <span data-t="voiceGuided">Voz guiada</span> <span id="voiceStatus" style="color:var(--muted);font-weight:400">activada</span></span>
    </div>
    <div class="toggle-switch on" id="voiceSwitch"></div>
  </div>

  <div class="toggle-row" onclick="toggleMusic()">
    <div class="toggle-row-label">
      <span class="toggle-icon" id="musicIcon">🎵</span>
      <span data-t="bgMusic">Música de fondo</span> <span id="musicStatus" style="color:var(--muted);font-weight:400">activada</span></span>
    </div>
    <div class="toggle-switch on" id="musicSwitch"></div>
  </div>

  <div class="volume-row">
    <div class="volume-top">
      <div class="volume-label" data-t="volumeLabel">🎚️ Volumen música</div>
      <div class="volume-value" id="volumeValue">60%</div>
    </div>
    <input type="range" class="volume-slider" id="volumeSlider" min="0" max="100" value="60" oninput="updateVolume(this.value)">
  </div>

  <div class="test-btns">
    <button class="test-btn" onclick="testVoice(event)" data-t="testVoice">🎙️ Probar voz</button>
    <button class="test-btn" onclick="testMusic(event)" data-t="testMusic">🎵 Probar música</button>
  </div>

  <div id="debugLog"></div>

  <div class="day-progress">
    <div class="day-progress-top">
      <div class="day-progress-label" data-t="todayProgress">Progreso de hoy</div>
      <div class="day-progress-count" id="dayCount">0 / 7</div>
    </div>
    <div class="day-progress-bar"><div class="day-progress-fill" id="dayFill" style="width:0%"></div></div>
  </div>

  <div class="section-title" data-t="sectionTitle">Tu rutina · Toca para empezar</div>

  <div class="block-card" data-type="breathing" onclick="startBlock('breathing')">
    <div class="block-time">08:00 — 10 MIN</div>
    <div class="block-title" data-t="blockBreathing">🫁 Respiración</div>
    <div class="block-meta"><span>3 técnicas</span><span>•</span><span>Ritmo guiado</span></div>
    <div class="block-chevron">›</div>
  </div>

  <div class="block-card" data-type="core" onclick="startBlock('core')">
    <div class="block-time">08:10 — 20 MIN</div>
    <div class="block-title" data-t="blockCore">💪 Abdomen + Core Sentado</div>
    <div class="block-meta"><span>8 ejercicios</span><span>•</span><span>+ Plataforma</span></div>
    <div class="block-chevron">›</div>
  </div>

  <div class="block-card" data-type="arms" onclick="startBlock('arms')">
    <div class="block-time">08:30 — 10 MIN</div>
    <div class="block-title" data-t="blockArms">🎯 Bandas + Mancuernas</div>
    <div class="block-meta"><span>7 ejercicios</span><span>•</span><span>Adaptado FSHD</span></div>
    <div class="block-chevron">›</div>
  </div>

  <div class="block-card" data-type="compex" onclick="startBlock('compex')">
    <div class="block-time">08:40 — 50 MIN</div>
    <div class="block-title" data-t="blockCompex">⚡ Electroestimulación</div>
    <div class="block-meta"><span>2 zonas · 25 min</span><span>•</span><span>Tonificación</span></div>
    <div class="block-chevron">›</div>
  </div>

  <div class="block-card" data-type="stretch" onclick="startBlock('stretch')">
    <div class="block-time">09:30 — 10 MIN</div>
    <div class="block-title" data-t="blockStretch">🧘 Estiramientos</div>
    <div class="block-meta"><span>10 estiramientos</span><span>•</span><span>Todo sentado</span></div>
    <div class="block-chevron">›</div>
  </div>

  <div class="block-card" data-type="bike" onclick="startBlock('bike')">
    <div class="block-time">13:30 — 15 MIN</div>
    <div class="block-title" data-t="blockBike">🚴 Bicicleta Estática</div>
    <div class="block-meta"><span>HIIT intervalos</span><span>•</span><span>15 min</span></div>
    <div class="block-chevron">›</div>
  </div>

  <div class="block-card" data-type="bed" onclick="startBlock('bed')">
    <div class="block-time">22:30 — 20 MIN</div>
    <div class="block-title">🛌 Yoga en Cama</div>
    <div class="block-meta"><span>8 posturas suaves</span><span>•</span><span>Sin giros bruscos</span></div>
    <div class="block-chevron">›</div>
  </div>

  <div style="margin-top:32px;text-align:center;font-size:11px;color:var(--muted);letter-spacing:1px;">PROTOCOLO ADAPTADO · HOMBROS Y CADERA PROTEGIDOS</div>
</div>

<div class="trainer" id="trainer">
  <div class="trainer-top">
    <button class="close-btn" onclick="stopTrainer()">✕</button>
    <div class="trainer-counter">
      <span id="trainerCounter">1 / 5</span>
      <small id="trainerBlockName">BLOQUE</small>
    </div>
    <button class="skip-btn" onclick="skipCurrent()">⏭</button>
  </div>
  <div class="trainer-progress"><div class="trainer-progress-fill" id="trainerProgress"></div></div>
  <div class="trainer-image">
    <img id="trainerImg" src="" alt="" onerror="if(window.handleImgError)window.handleImgError()">
    <div id="trainerEmoji" class="fallback-emoji" style="display:none"></div>
    <div id="trainerEmojiLabel" class="fallback-label" style="display:none"></div>
    <div class="timer-overlay" id="timerOverlay">
      <div class="timer-overlay-display" id="bigTimer">00:30</div>
    </div>
  </div>
  <div class="trainer-content">
    <div id="exerciseMode">
      <div class="trainer-name" id="trainerName"></div>
      <div class="trainer-reps" id="trainerReps"></div>
      <div class="cue-box" id="cueBox"><div class="cue-text" id="cueText">—</div></div>
      <div class="trainer-desc" id="trainerDesc"></div>
    </div>
    <div id="restMode" style="display:none;width:100%">
      <div class="rest-badge" data-t="rest">DESCANSO</div>
      <div class="big-timer-display" id="restTimer">00:10</div>
      <div class="rest-next" data-t="nextExercise">Siguiente ejercicio</div>
      <div class="rest-next-name" id="restNextName">—</div>
    </div>
    <div id="readyMode" style="display:none;width:100%">
      <div class="ready-label" data-t="getReady">Prepárate</div>
      <div class="ready-countdown" id="readyCount">3</div>
    </div>
    <div id="completeMode" style="display:none;width:100%">
      <div class="complete-icon">✓</div>
      <div class="complete-title" data-t="blockDone">¡BLOQUE COMPLETADO!</div>
      <div class="complete-sub" data-t="blockDoneSub">Buen trabajo 💪</div>
    </div>
  </div>
  <div class="trainer-controls">
    <button class="ctrl-btn" onclick="prevExercise()">← Atrás</button>
    <button class="ctrl-btn primary pause" id="mainBtn" onclick="togglePause()" data-t="pauseBtn">Pausar</button>
    <button class="ctrl-btn" onclick="nextExercise()">Saltar →</button>
  </div>
</div>

<!-- Video invisible para evitar bloqueo de pantalla en Xiaomi -->
<video id="nosleepVid" playsinline muted loop style="position:fixed;width:1px;height:1px;opacity:0.01;pointer-events:none;z-index:-1"></video>

<script>
// ============================================
// WORKOUTS — Ejercicios adaptados a FSHD con movilidad reducida
// ============================================

const WORKOUTS = {
  breathing: {
    title: "RESPIRACIÓN", restTime: 5,
    exercises: [
      { name:"Box Breathing", reps:"4-4-4-4", duration:240, emoji:"🫁", gifs:["data:image/jpeg;base64,"],
        desc:"Sigue el ritmo de la voz. 4 segundos cada fase.",
        cycle:[
          {cue:"INSPIRA", say:"Inspira", seconds:4, color:"inhale"},
          {cue:"AGUANTA", say:"Aguanta", seconds:4, color:"hold"},
          {cue:"EXHALA", say:"Exhala", seconds:4, color:"exhale"},
